---
import { twMerge } from "tailwind-merge";
import { buildBarRects, VIEW_W, BAND_VIEW_H } from "./dots";

type Props = {
    class?: string;
};

const { class: className } = Astro.props;

const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${VIEW_W} ${BAND_VIEW_H}">${buildBarRects()}</svg>`;
const mask = `url("data:image/svg+xml,${encodeURIComponent(svg)}")`;
---

<div
    class={twMerge(className)}
    style={`--dot-size:1em;height:calc(${BAND_VIEW_H}*var(--dot-size));background-color:var(--color-muted);-webkit-mask-image:${mask};mask-image:${mask};mask-size:calc(${VIEW_W}*var(--dot-size)) 100%;mask-repeat:repeat-x`}
>
</div>
