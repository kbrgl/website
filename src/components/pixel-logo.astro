---
import { getFilledCells, STEP, VIEW_W, VIEW_H } from "./pixel-pattern";
const cells = getFilledCells();
---

<a href="/" class="font-bold flex items-center gap-2" data-pixel-logo>
    <svg
        viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
        style={`--dot-size:calc(var(--height,1em)/${VIEW_H});width:calc(${VIEW_W}*var(--dot-size));height:calc(${VIEW_H}*var(--dot-size))`}
        aria-hidden="true"
    >
        {cells.map(({ c, r }) => <circle cx={c * STEP + 0.5} cy={r * STEP + 0.5} r="0.5" />)}
    </svg>
    <span class="leading-none">Kabir Goel</span>
</a>

<style>
    [data-pixel-logo] circle {
        fill: var(--dot-color, var(--color-muted-foreground));
    }
    [data-pixel-logo] circle.lit {
        fill: var(--dot-color-lit, var(--color-secondary));
    }
</style>

<script>
    document
        .querySelectorAll<SVGElement>("[data-pixel-logo]")
        .forEach((logo) => {
            const dots = Array.from(
                logo.querySelectorAll<SVGCircleElement>("circle"),
            );
            let timer: ReturnType<typeof setInterval> | null = null;

            function cycle() {
                dots.forEach((d) => d.classList.remove("lit"));
                const count = Math.floor(Math.random() * 4) + 2;
                dots.slice()
                    .sort(() => Math.random() - 0.5)
                    .slice(0, count)
                    .forEach((d) => d.classList.add("lit"));
            }

            logo.addEventListener("mouseenter", () => {
                cycle();
                timer = setInterval(cycle, 250);
            });

            logo.addEventListener("mouseleave", () => {
                clearInterval(timer!);
                timer = null;
                dots.forEach((d) => d.classList.remove("lit"));
            });
        });
</script>
