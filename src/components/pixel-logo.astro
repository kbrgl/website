---
import { circleMask, VIEW_W, VIEW_H } from "./pixel-pattern";

const { mask, viewH } = circleMask();
---

<div
    style={`--dot-size:calc(var(--height,1em)/${viewH});width:calc(${VIEW_W}*var(--dot-size));height:calc(${viewH}*var(--dot-size));background-color:var(--dot-color,var(--color-muted-foreground));-webkit-mask-image:${mask};mask-image:${mask};mask-size:100% 100%`}
/>
